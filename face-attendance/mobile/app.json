{
  "expo": {
    "name": "Điểm danh lớp học",
    "slug": "face-attendance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3B5998"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.faceattendance.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Ứng dụng cần camera để nhận diện khuôn mặt và điểm danh sinh viên.",
        "NSPhotoLibraryUsageDescription": "Ứng dụng cần truy cập ảnh để chọn ảnh điểm danh hoặc đăng ký khuôn mặt."
      }
    },
    "android": {
      "package": "com.faceattendance.app",
      "adaptiveIcon": {
        "backgroundColor": "#3B5998",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-camera",
        {
          "cameraPermission": "Ứng dụng cần camera để nhận diện khuôn mặt và điểm danh sinh viên.",
          "microphonePermission": "Ứng dụng cần micro để ghi video điểm danh."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Ứng dụng cần truy cập ảnh để chọn ảnh điểm danh."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "face-attendance-local"
      }
    }
  }
}
